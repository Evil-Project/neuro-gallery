{
  "name": "neuro-gallery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:worker": "npm run build && wrangler dev --local --port 8787",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260607.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.98.0"
  }
}
